# ─── REQUIRED ─────────────────────────────────────────────────────────────────
# Get from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id

# ─── OPTIONAL (free tiers, improves accuracy) ─────────────────────────────────
# Groq — FREE AI (Llama 3 70B). Get key at https://console.groq.com (no credit card)
# Powers: !analyze and !ask commands
GROQ_API_KEY=your_groq_api_key_here

# GoPlusLabs — https://docs.gopluslabs.io (free, no key needed for basic calls)
GOPLUS_API_KEY=

# Etherscan — https://etherscan.io/apis (free tier: 5 req/sec)
ETHERSCAN_API_KEY=your_etherscan_api_key

# ─── BOT CONFIG ───────────────────────────────────────────────────────────────
PREFIX=!
# Newsie branding link appended to all responses
NEWSIE_URL=https://newsie.tech
